# Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Connection String
# Get this from https://cloud.mongodb.com (free tier available)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/ceynova?retryWrites=true&w=majority

# JWT Secret - make this a long random string
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Admin Credentials (used only for the initial seed / login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ceynova2026

# Server Port
PORT=5000

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
